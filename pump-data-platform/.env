# 应用配置
APP_NAME="Pump Valve Monitoring Platform"
APP_VERSION="1.0.0"
DEBUG=true

# 数据库配置（Docker 内部使用）
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=pump_data

# InfluxDB 配置
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=pump_data

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 数据源配置 - 改为 MQTT
DATA_SOURCE_TYPE=mqtt

# API 数据源配置
API_BASE_URL=
API_TOKEN=
API_ENDPOINT=/api/pump-data

# MQTT 数据源配置
MQTT_BROKER=10.20.110.60
MQTT_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=Tsit@2023
MQTT_TOPIC=/iot/data
MQTT_CLIENT_ID=pump-valve-mqtt

# 采集配置
COLLECTION_INTERVAL=5

# 预警阈值
PRESSURE_THRESHOLD=2.0
FLOW_THRESHOLD=5.0
TEMPERATURE_THRESHOLD=80.0

# 关闭本地模式，使用真实数据库
LOCAL_MODE=false
